# ── Application ───────────────────────────────────────────────────────────────
APP_NAME=grafana-ai-agent
APP_VERSION=0.1.0
DEBUG=false
LOG_LEVEL=INFO

# ── Server ────────────────────────────────────────────────────────────────────
HOST=0.0.0.0
PORT=8000

# ── CORS ──────────────────────────────────────────────────────────────────────
# JSON list of allowed origins
CORS_ORIGINS=["http://localhost:5173","http://localhost:3000"]

# ── LLM provider ──────────────────────────────────────────────────────────────
# "ollama" (local) or "anthropic"
LLM_PROVIDER=ollama

# ── Ollama (runs on host — NOT in Docker) ─────────────────────────────────────
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3
OLLAMA_TIMEOUT=120.0

# ── Anthropic (only used when LLM_PROVIDER=anthropic) ─────────────────────────
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-opus-4-6

# ── Grafana ───────────────────────────────────────────────────────────────────
# URL of your Grafana instance
GRAFANA_BASE_URL=https://your-grafana.example.com
# Create a service account token in Grafana → Administration → Service accounts
GRAFANA_API_KEY=

# ── Loki ──────────────────────────────────────────────────────────────────────
# Direct URL to your Loki instance (used for log queries)
LOKI_BASE_URL=https://your-loki.example.com

# ── Prometheus ────────────────────────────────────────────────────────────────
# Direct URL to your Prometheus instance (used for metric queries)
PROMETHEUS_BASE_URL=https://your-prometheus.example.com

# ── Tempo ─────────────────────────────────────────────────────────────────────
# Direct URL to your Tempo instance (used for trace queries)
TEMPO_BASE_URL=https://your-tempo.example.com

# ── Qdrant (vector store — started via docker-compose.dev.yml) ─────────────────
QDRANT_URL=http://localhost:6333
QDRANT_COLLECTION=query_examples
EMBEDDING_MODEL=nomic-embed-text
EMBEDDING_VECTOR_SIZE=768

# ── SQLite (entity store) ──────────────────────────────────────────────────────
SQLITE_DB_PATH=./data/grafana_ai.db
