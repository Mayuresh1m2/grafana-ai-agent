# ── Application ───────────────────────────────────────────────────────────────
APP_NAME=grafana-ai-agent
APP_VERSION=0.1.0
DEBUG=false
LOG_LEVEL=INFO

# ── Server ────────────────────────────────────────────────────────────────────
HOST=0.0.0.0
PORT=8000

# ── CORS ──────────────────────────────────────────────────────────────────────
# JSON list of allowed origins
CORS_ORIGINS=["http://localhost:5173","http://localhost:3000"]

# ── Ollama (runs on host — NOT in Docker) ─────────────────────────────────────
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3
OLLAMA_TIMEOUT=120.0

# ── Grafana ───────────────────────────────────────────────────────────────────
GRAFANA_BASE_URL=http://localhost:3000
# Create a service account token in Grafana and paste it here
GRAFANA_API_KEY=

# ── Loki ──────────────────────────────────────────────────────────────────────
LOKI_BASE_URL=http://localhost:3100

# ── Prometheus ────────────────────────────────────────────────────────────────
PROMETHEUS_BASE_URL=http://localhost:9090

# ── Tempo ─────────────────────────────────────────────────────────────────────
TEMPO_BASE_URL=http://localhost:3200
